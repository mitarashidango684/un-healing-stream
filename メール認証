<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>Firebase認証テスト</title>
</head>
<body>

  <h1>Firebase メールアドレス認証テスト</h1>

  <div id="auth-form">
    <input type="email" id="email" placeholder="メールアドレス"><br><br>
    <input type="password" id="password" placeholder="パスワード"><br><br>
    <button id="signup-btn">新規登録</button>
    <button id="login-btn">ログイン</button>
  </div>

  <div id="welcome-screen" style="display: none;">
    <p>ようこそ！ <span id="user-email"></span> さん</p>
    <button id="logout-btn">ログアウト</button>
  </div>

  <script type="module">
    // 1. Firebase SDKの必要な機能をインポート
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.0.0/firebase-app.js";
    import { 
      getAuth, 
      createUserWithEmailAndPassword, 
      signInWithEmailAndPassword, 
      signOut,
      onAuthStateChanged 
    } from "https://www.gstatic.com/firebasejs/10.0.0/firebase-auth.js";

    // 2. あなたのFirebaseプロジェクトの設定情報（※ここに自分の設定を貼り付ける）
    const firebaseConfig = {
apiKey:"AIzaSyCDGZcgQGa1z1FLv2ZIo5RrESNfhW2KmPA"
      authDomain: "mail-47a07.firebaseapp.com",
      projectId: "mail-47a07",
      storageBucket: "mail-47a07.firebasestorage.app",
      messagingSenderId: "450950977278",
appId:"1:450950977278:web:697a127f30c3457b88b7af",
    };

    // 3. Firebaseの初期化
    const app = initializeApp(firebaseConfig);
    const auth = getAuth(app);

    // HTML要素の取得
    const emailInput = document.getElementById('email');
    const passwordInput = document.getElementById('password');
    const signupBtn = document.getElementById('signup-btn');
    const loginBtn = document.getElementById('login-btn');
    const logoutBtn = document.getElementById('logout-btn');
    const authForm = document.getElementById('auth-form');
    const welcomeScreen = document.getElementById('welcome-screen');
    const userEmailSpan = document.getElementById('user-email');

    // --- A. 新規登録処理 ---
    signupBtn.addEventListener('click', async () => {
      const email = emailInput.value;
      const password = passwordInput.value;
      try {
        await createUserWithEmailAndPassword(auth, email, password);
        alert('ユーザー登録に成功しました！');
      } catch (error) {
        alert('登録エラー: ' + error.message);
      }
    });

    // --- B. ログイン処理 ---
    loginBtn.addEventListener('click', async () => {
      const email = emailInput.value;
      const password = passwordInput.value;
      try {
        await signInWithEmailAndPassword(auth, email, password);
        alert('ログインしました！');
      } catch (error) {
        alert('ログインエラー: ' + error.message);
      }
    });

    // --- C. ログアウト処理 ---
    logoutBtn.addEventListener('click', async () => {
      try {
        await signOut(auth);
        alert('ログアウトしました');
      } catch (error) {
        alert('ログアウトエラー: ' + error.message);
      }
    });

    // --- D. ログイン状態の監視 ---
    // ページを開いた時や、ログイン・ログアウトした時に自動で実行されます
    onAuthStateChanged(auth, (user) => {
      if (user) {
        // ログインしている場合：マイページを表示
        authForm.style.display = 'none';
        welcomeScreen.style.display = 'block';
        userEmailSpan.textContent = user.email;
      } else {
        // ログインしていない場合：フォームを表示
        authForm.style.display = 'block';
        welcomeScreen.style.display = 'none';
      }
    });
  </script>
</body>
</html>
